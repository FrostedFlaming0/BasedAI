# Copy to .env and fill in.

# Chain RPCs
INK_RPC=https://rpc-gel.inkonchain.com
INK_SEPOLIA_RPC=https://rpc-gel-sepolia.inkonchain.com
MAINNET_RPC=https://eth.llamarpc.com

# Block explorer API key (Routescan or equivalent for Ink)
INK_EXPLORER_API_KEY=

# Deployer
DEPLOYER_PRIVATE_KEY=

# Operational
ADMIN=
GOVERNANCE=

# Existing tokens (Ethereum mainnet)
PEPECOIN=0xA9E8aCf069C58aEc8825542845Fd754e41a9489A
BASEDAI=0x44971ABF0251958492FeE97dA3e5C5adA88B9185

# Bridged $basedAI on Ink L2 (set after bridging via inkonchain.com)
BASEDAI_L2=

# L2 deployment outputs (set after running Deploy.s.sol)
BRAIN_NFT_L2=

# Ink's canonical L1 ERC-721 bridge (look up from Ink docs)
L1_NFT_BRIDGE=

# Brain stake amounts (initial, governance-adjustable)
PEPE_STAKE=100000000000000000000000      # 100,000 PEPE (18 decimals)
BASED_STAKE=10000000000000000000000      # 10,000 basedAI (18 decimals)

# Miner / validator
MINER_PRIVATE_KEY=
VALIDATOR_PRIVATE_KEY=
